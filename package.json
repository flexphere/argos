{
  "name": "argos",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:skill": "node scripts/build-skill.mjs",
    "start": "next start",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "lint": "biome check .",
    "format": "biome format --write .",
    "check:dead": "knip",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": ["biome check --apply --no-errors-on-unmatched"]
  },
  "dependencies": {
    "@xyflow/react": "^12.10.2",
    "next": "^16.2.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.23.8",
    "zundo": "^2.3.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitest/coverage-v8": "^2.1.9",
    "esbuild": "^0.28.0",
    "happy-dom": "^20.9.0",
    "husky": "^9.1.7",
    "knip": "^6.14.2",
    "lint-staged": "^17.0.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
